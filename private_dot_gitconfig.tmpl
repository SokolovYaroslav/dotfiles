[alias]
  co = checkout
  ci = commit
  st = status
  br = branch
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  type = cat-file -t
  dump = cat-file -p

[user]
	email = 22151264+SokolovYaroslav@users.noreply.github.com
	name = Yaroslav Sokolov
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIIZ4W1jMvkXdBx/PS3ohfsF7BKyFOkSHX/3PXb4EeKtj

[core]
	autocrlf = input

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Commit signing via the 1Password SSH agent (no local private key on disk).
[gpg]
	format = ssh
[gpg "ssh"]
{{- if eq .chezmoi.os "darwin" }}
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- else }}
	program = /opt/1Password/op-ssh-sign
{{- end }}
[commit]
	gpgsign = true
