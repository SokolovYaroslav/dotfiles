#!/usr/bin/env bash
{{- if .installGh }}
# Install the GitHub CLI and log in (gh config/token is intentionally NOT in this repo).
set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
{{- if eq .chezmoi.os "darwin" }}
  # brew may have just been installed this run but not yet on PATH — load its shellenv.
  if [ -x /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)"; fi
  if command -v brew >/dev/null 2>&1; then
    brew install gh
  else
    echo "gh not found and Homebrew unavailable — install gh manually, then re-run: chezmoi apply"
    exit 0
  fi
{{- else }}
  if command -v apt-get >/dev/null 2>&1; then
    # Official GitHub apt repo (needs sudo). https://github.com/cli/cli/blob/trunk/docs/install_linux.md
    echo "Installing GitHub CLI via apt (needs sudo)…"
    sudo mkdir -p -m 755 /etc/apt/keyrings
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
    sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
    sudo apt-get update && sudo apt-get install -y gh
  else
    echo "gh not found and apt unavailable — install gh manually, then re-run: chezmoi apply"
    exit 0
  fi
{{- end }}
fi

if ! gh auth status >/dev/null 2>&1; then
  gh auth login
fi
{{- else }}
# gh install/login skipped (installGh = false)
{{- end }}
