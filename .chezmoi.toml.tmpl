{{- /* Wizard prompts. Answers are stored in chezmoi's persistent state and asked only once. */ -}}
{{- $opAccount := promptStringOnce . "opAccount" "1Password account shorthand (e.g. my.1password.com)" -}}
{{- $useOpSsh := promptBoolOnce . "useOnePasswordSshAgent" "Use the 1Password SSH agent (also used for git commit signing)?" -}}
{{- $enableJbProxy := promptBoolOnce . "enableJbProxy" "Install & wire the JetBrains AI proxy via central (installs, logs in, runs 'central add claude-code' to route Claude through it)?" -}}
{{- $installGh := promptBoolOnce . "installGh" "Install the GitHub CLI (gh) and run 'gh auth login'?" -}}
{{- $enableMcp := promptBoolOnce . "enableMcp" "Register the YouTrack MCP server for Claude Code?" -}}
{{- $installSkills := promptBoolOnce . "installSkills" "Install my private global Claude Code skills (from a separate private git repo)?" -}}
{{- $skillsRepo := "" -}}
{{- if $installSkills -}}
{{-   $skillsRepo = promptStringOnce . "skillsRepo" "Git URL of the private skills repo (e.g. git@github.com:you/claude-skills.git)" -}}
{{- end -}}

[data]
    opAccount = {{ $opAccount | quote }}
    useOnePasswordSshAgent = {{ $useOpSsh }}
    enableJbProxy = {{ $enableJbProxy }}
    installGh = {{ $installGh }}
    enableMcp = {{ $enableMcp }}
    installSkills = {{ $installSkills }}
    skillsRepo = {{ $skillsRepo | quote }}
