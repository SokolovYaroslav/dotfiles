#!/usr/bin/env bash
{{- if .enableJbProxy }}
# JetBrains AI proxy (internal). Requires the `central` CLI (formerly `jbcentral`;
# that name lingers as a back-compat alias but `central` is canonical).
set -euo pipefail

if ! command -v central >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/central" ]; then
  case "$(uname -s)" in
    Darwin|Linux)
      echo "Installing central…"
      curl -fsSL https://jetbrains-central-cli.s3.eu-west-1.amazonaws.com/jbcentral/stable/install.sh | bash
      ;;
    *)
      echo "Install central for your OS (see https://central-cli.labs.jb.gg/docs), then re-run: chezmoi apply"
      exit 0
      ;;
  esac
fi

export PATH="$HOME/.local/bin:$PATH"   # install.sh drops the binary here
if ! command -v central >/dev/null 2>&1; then
  echo "central still not found after install — see https://central-cli.labs.jb.gg/docs, then re-run: chezmoi apply"
  exit 0
fi

# Authenticate, then wire Claude Code to route through the proxy globally. `central add`
# writes `apiKeyHelper` + `env.ANTHROPIC_BASE_URL` (the per-machine proxy wire) into
# ~/.claude/settings.json itself — the modify_ settings script preserves those keys on
# every future `chezmoi apply`, so we never have to ask for or store the wire URL. Every
# `claude` launch then routes through the proxy with no extra flags.
central login || true
central add claude-code
{{- else }}
# JetBrains proxy setup skipped (enableJbProxy = false)
{{- end }}
