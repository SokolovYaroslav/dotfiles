# Rust/Cargo env, if present.
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi

# YouTrack REST API. The token lives in 1Password and is resolved ON DEMAND,
# never at shell init (so a plain shell start does not trigger an op unlock)
# and never stored on disk.
#   yt_token  -> prints the token (resolves from 1Password each call)
#   yt_auth   -> exports YOUTRACK_TOKEN for the current shell (caches it)
export YOUTRACK_BASE_URL="https://youtrack.jetbrains.com"
yt_token() { op item get 'YT Token' --account {{ .opAccount }} --fields label=credential --reveal 2>/dev/null; }
yt_auth()  { export YOUTRACK_TOKEN="${YOUTRACK_TOKEN:-$(yt_token)}"; }

# Anthropic API key on demand (field 'credential' of the 'Anthropic API key dev' item).
anthropic_key() { op item get 'Anthropic API key dev' --account {{ .opAccount }} --fields label=credential --reveal 2>/dev/null; }

# Claude Code needs no secret injection at launch: MCP servers that require secrets are
# registered as self-authorizing (they resolve from 1Password via `op run` when Claude
# spawns them — see run_onchange_after_40-mcp.sh.tmpl). So `claude` is invoked as the
# plain binary, which also means it behaves identically when launched from the IDE's
# Agent Workbench rather than this shell. Proxy routing is baked into
# ~/.claude/settings.json by `central add claude-code`.

# Machine-specific overrides (not tracked by chezmoi).
if [ -f "$HOME/.zshenv.local" ]; then
    source "$HOME/.zshenv.local"
fi

# Langfuse agent tracing (personal opt-in; overrides agent/app/.env under uv run --env-file)
export LANGFUSE_TRACING=true
export LANGFUSE_TRACING_ENVIRONMENT=yas
