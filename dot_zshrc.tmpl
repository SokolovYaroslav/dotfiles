# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Theme. See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="robbyrussell"

# Plugins. Standard plugins live in $ZSH/plugins/; custom in $ZSH/custom/plugins/.
plugins=(git zsh-autosuggestions)

source $ZSH/oh-my-zsh.sh

# Show the full path (~/-abbreviated) in the prompt instead of just the current
# directory's last component. robbyrussell uses %c; swap it for %~ post-source so
# the (externally-managed) theme file stays untouched.
PROMPT=${PROMPT//"%c"/"%~"}

# User configuration

export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
{{ if .useOnePasswordSshAgent }}
# Route ssh-agent through 1Password (keys live there). ssh/git also use the agent
# via IdentityAgent in ~/.ssh/config; this points sock-reading tools at it too.
{{- if eq .chezmoi.os "darwin" }}
_op_ssh_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
_op_ssh_sock="$HOME/.1password/agent.sock"
{{- end }}
if [ -S "$_op_ssh_sock" ]; then
    export SSH_AUTH_SOCK="$_op_ssh_sock"
{{- if eq .chezmoi.os "darwin" }}
elif [ -z "$SSH_AUTH_SOCK" ]; then
    # Fall back to the launchd agent if 1Password isn't running.
    export SSH_AUTH_SOCK=$(find /private/tmp/com.apple.launchd.*/Listeners /var/run/com.apple.launchd.*/Listeners -user "$USER" 2>/dev/null | head -1)
{{- end }}
fi
unset _op_ssh_sock
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# awake — toggle a caffeinate assertion to keep this Mac from sleeping.
#   awake   turn on (stay awake indefinitely), or off if already on
# Tracks only the process it starts (via a PID file), so toggling off never kills
# caffeinate assertions started elsewhere (e.g. `caffeinate -di make`). When
# turning off, it warns if any *other* caffeinate is still holding the Mac awake.
awake() {
    local pidfile="${TMPDIR:-/tmp}/awake.caffeinate.pid"
    local pid
    pid=$(cat "$pidfile" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null
        rm -f "$pidfile"
        echo "☕ awake off — sleep re-enabled"
        local others
        others=$(pgrep -x caffeinate 2>/dev/null | grep -v "^${pid}$" | tr '\n' ' ')
        if [ -n "${others// /}" ]; then
            echo "⚠️  other caffeinate still keeping the Mac awake (pid ${others% })"
            echo "    inspect: pmset -g assertions   ·   reset all: pkill caffeinate"
        fi
    else
        rm -f "$pidfile"
        caffeinate -dimsu &
        echo "$!" > "$pidfile"
        echo "☕ awake on — staying awake (pid $!)"
    fi
}
{{ end -}}
# Machine-specific overrides (not tracked by chezmoi). Put host-only PATH entries
# (e.g. TinyTeX, language frameworks) here. Use a full if-block (not `&& source`)
# so a missing file leaves $? at 0 — otherwise the failed test makes every fresh
# prompt show robbyrussell's red arrow.
if [ -f "$HOME/.zshrc.local" ]; then
    source "$HOME/.zshrc.local"
fi
